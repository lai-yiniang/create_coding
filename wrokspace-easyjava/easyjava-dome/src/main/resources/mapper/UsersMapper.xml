		</if>
		<if test="query.phone != null and query.phone!=''">
			 and phone = #{query.phone} 
		</if>
		<if test="query.updateTime != null ">
			 and update_time = #{query.updateTime} 
		</if>
		<if test="query.createTime != null ">
			 and create_time = #{query.createTime} 
		</if>
		</sql>
	<!--扩展查询条件-->
	<sql id="baseQueryConditionExtend">
		<if test="query.usernameFuzzy != null and query.usernameFuzzy != ''">
			and username like concat('%', #{query.usernameFuzzy},'%')
		</if>
		<if test="query.orderCodeFuzzy != null and query.orderCodeFuzzy != ''">
			and order_code like concat('%', #{query.orderCodeFuzzy},'%')
		</if>
		<if test="query.genderFuzzy != null and query.genderFuzzy != ''">
