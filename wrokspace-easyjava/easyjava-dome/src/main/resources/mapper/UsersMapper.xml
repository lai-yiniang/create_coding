		</if>
		<if test="query.phoneFuzzy != null and query.phoneFuzzy != ''">
			and phone like concat('%', #{query.phoneFuzzy},'%')
		</if>
		<if test="query.updateTimeStartTime != null and query.updateTimeStartTime != ''">
			<![CDATA[ and update_time >= str_to_date(#{query.updateTimeStartTime}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.updateTimeEndTime != null and query.updateTimeEndTime != ''">
			<![CDATA[ and update_time < str_to_date(#{query.updateTimeEndTime}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.createTimeStartTime != null and query.createTimeStartTime != ''">
			<![CDATA[ and create_time >= str_to_date(#{query.createTimeStartTime}, '%Y-%m-%d') ]]>
		</if>
		<if test="query.createTimeEndTime != null and query.createTimeEndTime != ''">
			<![CDATA[ and create_time < str_to_date(#{query.createTimeEndTime}, '%Y-%m-%d') ]]>
		</if>
	</sql>
	<!--通用查询条件-->
	<sql id="queryCondition">
		<where>
			<include refid="baseQueryCondition"/>
			<include refid="baseQueryConditionExtend"/>
		</where>
	</sql>
